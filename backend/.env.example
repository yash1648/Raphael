# Raphael Configuration — copy to .env and fill in your keys

# ── LLM Providers (Free) ───────────────────────────────────
# NVIDIA NIMs (default) — https://build.nvidia.com/explore/discover
# Get key at: https://ngc.nvidia.com/setup/api-key
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter — https://openrouter.ai/keys
# Routes to 200+ models across all providers (many free)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ollama (local, no key needed) — https://ollama.ai
# Just install Ollama and pull a model: ollama pull llama3

# ── Default LLM ────────────────────────────────────────────
# Options: nvidia, openrouter, ollama
DEFAULT_LLM_PROVIDER=nvidia
DEFAULT_LLM_MODEL=meta/llama-3.1-70b-instruct

# ── Database ───────────────────────────────────────────────
DATABASE_URL=sqlite:///./raphael.db

# ── Memory ─────────────────────────────────────────────────
MEMORY_PERSIST_DIR=./chroma_memory

# ── Code Sandbox ───────────────────────────────────────────
CODE_EXECUTION_TIMEOUT=30
CODE_MAX_OUTPUT=10000

# ── Server ─────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
